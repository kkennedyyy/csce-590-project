# Docker compose defaults for local plug-and-play startup.
MSSQL_SA_PASSWORD=Your_password123
MSSQL_DB_NAME=ClassFinderDb
SEED_DATA_ON_STARTUP=true
VITE_API_BASE_URL=http://localhost:8080

# Backend configuration
CONNECTIONSTRINGS__DEFAULTCONNECTION=Server=localhost,1433;Database=ClassFinderDb;User Id=sa;Password=Your_password123;TrustServerCertificate=true
NOTIFICATIONS__ENABLED=true
NOTIFICATIONS__DIRECTEMAILENABLED=false
NOTIFICATIONS__FROMEMAIL=noreply@classfinder.local
NOTIFICATIONS__FROMDISPLAYNAME=ClassFinder
NOTIFICATIONS__PICKUPDIRECTORY=App_Data/maildrop
NOTIFICATIONS__SMTPHOST=
NOTIFICATIONS__SMTPPORT=25
NOTIFICATIONS__AZURECOMMUNICATIONCONNECTIONSTRING=
NOTIFICATIONS__AZURECOMMUNICATIONSENDERADDRESS=
NOTIFICATIONS__OUTLOOKCONNECTIONRESOURCEID=
NOTIFICATIONS__SERVICEBUSCONNECTIONSTRING=
NOTIFICATIONS__SERVICEBUSENTITYNAME=classfinder-registration-events
NOTIFICATIONS__WORKFLOWWEBHOOKKEY=

# External source configuration for Azure Data Factory deployment
CLASS_API_BASE_URL=
CLASS_API_FUNCTION_KEY=
STUDENTS_BLOB_SAS_URL=
PROFESSORS_BLOB_SAS_URL=
